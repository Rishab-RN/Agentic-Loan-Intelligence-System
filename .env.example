# ══════════════════════════════════════════════════════════════
# ALIS — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed.

# ─── Ollama (Local LLM for ExplainerVoice) ───────────────────
# If Ollama is not running, ExplainerVoice uses template-only mode.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── API Ports ───────────────────────────────────────────────
# Each agent's FastAPI server runs on a separate port.
RISK_MIND_PORT=8000
FRAUD_SENTINEL_PORT=8001
COMPLIANCE_GUARD_PORT=8002
EXPLAINER_VOICE_PORT=8003

# ─── Dashboard ───────────────────────────────────────────────
STREAMLIT_PORT=8501

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
